# ============================================================================
# DSMI Agent - Environment Variables Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values before deployment
# ============================================================================

# Application Settings
ENV=production
APP_NAME=DSMI Agent
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# Database Configuration (Cloud SQL or self-managed PostgreSQL)
# ============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
# For Google Cloud SQL: postgresql+asyncpg://user:password@localhost/database
#   (Use Cloud SQL Proxy for secure connection)
DATABASE_URL=postgresql+asyncpg://dsmi_user:change-me@localhost:5432/dsmi_agent

# ============================================================================
# Redis Configuration (for task queue and caching)
# ============================================================================
# Format: redis://[:password]@host:port/db
# For Google Cloud: Use Memorystore for Redis or self-managed Redis
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Vector Database Configuration (Qdrant)
# ============================================================================
# Format: http://host:port or https://host:port for managed services
# For Google Cloud: Host Qdrant on Compute Engine or Kubernetes
QDRANT_URL=http://localhost:6333

# ============================================================================
# Authentication & Security
# ============================================================================
# Secret key for JWT token generation (use strong random string)
JWT_SECRET_KEY=your-secret-key-change-this-in-production-with-long-random-string
JWT_EXPIRATION_HOURS=24

# API key for admin operations
ADMIN_API_KEY=your-admin-key-change-this

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com,http://localhost:3000,http://localhost:8080

# ============================================================================
# Google Cloud Settings
# ============================================================================
# For Cloud Storage (if storing files)
GCS_BUCKET=your-gcs-bucket-name
GCP_PROJECT_ID=your-gcp-project-id

# ============================================================================
# LLM Configuration
# ============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_DAY=10000

# ============================================================================
# Monitoring & Logging
# ============================================================================
# Google Cloud Logging
SENTRY_DSN=

# Cloud Trace
ENABLE_CLOUD_TRACE=true

# ============================================================================
# Email Configuration (for notifications)
# ============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_PDF_EXPORT=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_VECTOR_SEARCH=true
